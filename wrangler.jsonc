{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "zagle",
  "compatibility_date": "2025-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "zagle"
    }
  ]
}
